{
  "name": "ezoffice",
  "version": "0.1.0",
  "description": "Offline-first desktop app for SME attendance, payroll, and inventory management",
  "author": "EZOffice Contributors",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "electron:dev": "vite",
    "build": "tsc -b && vite build",
    "build:installer": "npm run build && electron-builder --publish never",
    "build:portable": "npm run build && electron-builder --win portable --publish never",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@tanstack/react-query": "^5.101.1",
    "@types/pdfmake": "^0.3.3",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "pdfmake": "^0.3.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "tailwind-merge": "^3.6.0",
    "zkteco-js": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-electron": "^1.1.0"
  },
  "build": {
    "appId": "com.ezoffice.app",
    "productName": "EZOffice",
    "directories": {
      "buildResources": "build/assets",
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EZOffice"
    }
  }
}
