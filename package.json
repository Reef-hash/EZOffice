{
  "name": "ezoffice",
  "version": "0.2.6",
  "description": "Offline-first desktop app for SME attendance, payroll, and inventory management",
  "author": "EZOffice Contributors",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "electron:dev": "vite",
    "build": "tsc -b && vite build",
    "build:installer": "npm run build && electron-builder --publish never",
    "build:portable": "npm run build && electron-builder --win portable --publish never",
    "preview": "vite preview",
    "typecheck": "npm run typecheck-app && npm run typecheck-node",
    "typecheck-app": "node node_modules/typescript/lib/tsc.js -p tsconfig.app.json --noEmit",
    "typecheck-node": "node node_modules/typescript/lib/tsc.js -p tsconfig.node.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@supabase/supabase-js": "^2.110.1",
    "@tanstack/react-query": "^5.101.1",
    "@types/pdfmake": "^0.3.3",
    "better-sqlite3": "^12.11.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.3.0",
    "exceljs": "^4.4.0",
    "node-machine-id": "^1.1.12",
    "pdfmake": "^0.3.11",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "tailwind-merge": "^3.6.0",
    "zkteco-js": "^1.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "electron": "^42.5.0",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-electron": "^1.1.0",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.ezoffice.app",
    "productName": "EZOffice",
    "publish": {
      "provider": "github",
      "owner": "Reef-hash",
      "repo": "EZOffice",
      "releaseType": "release"
    },
    "directories": {
      "buildResources": "build/assets",
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "electron/db/migrations",
        "to": "db/migrations"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "certificateFile": null,
      "certificatePassword": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EZOffice"
    }
  }
}
